AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_SESSION_TOKEN=your_session_token_here_if_using_temporary_credentials
AWS_DEFAULT_REGION=us-east-1

# Active inference profiles:
# Claude Haiku 4.5  (fast): us.anthropic.claude-haiku-4-5-20251001-v1:0
# Claude Sonnet 4.5:        us.anthropic.claude-sonnet-4-5-20250929-v1:0
BEDROCK_MODEL_ID=us.anthropic.claude-haiku-4-5-20251001-v1:0

# Optional: JWT secret (default is fine for dev)
# JWT_SECRET_KEY=your-secret-key-here

# ── SNS Notifications ──────────────────────────────────────────────────────
# Uses the same AWS credentials above. No extra config needed.
# A personal SNS topic is created per user on registration.
# User must click "Confirm subscription" in the AWS email to activate alerts.
#
# Notifications sent:
#   - Welcome email on registration
#   - Emission summary on analysis approval
#   - Emission spike alert (>20% increase vs previous record)
#   - Report generated confirmation
#
# Required IAM permissions:
#   sns:CreateTopic, sns:Subscribe, sns:Publish, sns:ListTopics, sns:TagResource
